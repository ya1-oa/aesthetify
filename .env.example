# ============================================================
# Aesthetify — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to git.
# ============================================================

# --- Shopify ---
# Found in: Shopify Admin > Apps > Hydrogen > Storefront API
PUBLIC_STORE_DOMAIN="your-store.myshopify.com"
PUBLIC_STOREFRONT_API_TOKEN="your-public-storefront-api-token"
# Private token (server-side only — never expose to browser)
PRIVATE_STOREFRONT_API_TOKEN="your-private-storefront-api-token"
PUBLIC_STOREFRONT_API_VERSION="2024-01"

# --- Sanity ---
# Found in: sanity.io > your project > API > Tokens
PUBLIC_SANITY_PROJECT_ID="your-sanity-project-id"
PUBLIC_SANITY_DATASET="production"
SANITY_API_TOKEN="your-sanity-read-token"
# For live preview (optional, set up later)
SANITY_PREVIEW_SECRET="a-random-secret-string"

# --- Session ---
# Generate with: openssl rand -hex 32
SESSION_SECRET="your-32-char-random-secret"
